<Window x:Class="Inchirieri.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inchirieri - Detalii Masina" Height="450" Width="800">
    <Grid Margin="8">
        <Grid.Resources>
            <!-- Common styles for the window, using brushes defined in App.xaml -->
            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="Margin" Value="4" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="BorderBrush" Value="{StaticResource TurquoiseDark}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TurquoiseDark}" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource TextBoxBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource TurquoiseMedium}" />
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="Margin" Value="0,2,0,2" />
                <Setter Property="Padding" Value="4" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="Margin" Value="0,2,0,6" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Menu -->
            <RowDefinition Height="*" />    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Application menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="Exit" />
            </MenuItem>
            <MenuItem Header="Actions">
                <MenuItem Header="Adaugă mașină" />
                <MenuItem Header="Închiriază mașină" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Refresh" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="Despre" />
            </MenuItem>
        </Menu>

        <!-- Main responsive layout -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <!-- Equal columns so panels keep equal widths when window is resized -->
                <ColumnDefinition Width="*" MinWidth="180" />
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="*" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <!-- Left: selection and actions -->
            <StackPanel Grid.Column="0" Margin="6" VerticalAlignment="Stretch" Background="{StaticResource PanelBrush}">
                <TextBlock Text="Mașini disponibile" FontSize="14" Margin="0,0,0,6" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="TxtCautareStanga" Margin="0,0,0,6" />
                <Button Content="Caută" Click="BtnSearchLeft_Click" Width="80" Margin="0,0,0,6" Background="{StaticResource ButtonBrush}" />
                <ComboBox x:Name="MasinaCombo" HorizontalAlignment="Stretch" SelectionChanged="MasinaCombo_SelectionChanged" />

                <UniformGrid Columns="3" Margin="0,10,0,0" HorizontalAlignment="Stretch">
                    <Button Content="Adaugă" Width="Auto" Margin="2" Background="{StaticResource ButtonBrush}" />
                    <Button Content="Șterge" Width="Auto" Margin="2" Background="{StaticResource ButtonBrush}" />
                    <Button Content="Închiriază" Width="Auto" Margin="2" Background="{StaticResource ButtonBrush}" />
                </UniformGrid>

                <Separator Margin="0,10,0,10" />

                <TextBlock Text="Filtre" Style="{StaticResource LabelStyle}" />
                <StackPanel Margin="0,6,0,0">
                    <CheckBox Content="Disponibile" IsChecked="True" />
                    <CheckBox Content="Cutie automată" />
                    <CheckBox Content="Aer condiționat" />
                </StackPanel>
            </StackPanel>

            <!-- Center: details area -->
            <Border Grid.Column="1" Margin="6" Padding="10" BorderBrush="{StaticResource TurquoiseDark}" BorderThickness="1" CornerRadius="6" Background="{StaticResource TurquoiseLight}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Detalii mașină" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtDetalii" Text="Selectează o mașină..." TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right: editor - add / edit entity -->
            <StackPanel Grid.Column="2" Margin="6" Background="{StaticResource PanelBrush}">
                <TextBlock Text="Editor mașină" FontSize="14" Style="{StaticResource LabelStyle}" />

                <TextBlock Text="Marca" Margin="0,8,0,0" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="TxtMarca" />

                <TextBlock Text="Model" Margin="0,8,0,0" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="TxtModel" />

                <TextBlock Text="Preț pe zi" Margin="0,8,0,0" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="TxtPret" />

                <CheckBox x:Name="ChkDisponibila" Content="Disponibilă" Margin="0,8,0,0" />

                <TextBlock Text="Culoare" Margin="0,8,0,0" />
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="RbCuloareNecunoscut" Content="Necunoscut" GroupName="Culoare" IsChecked="True" Margin="0,0,6,0" />
                    <RadioButton x:Name="RbCuloareRosu" Content="Roșu" GroupName="Culoare" Margin="0,0,6,0" />
                    <RadioButton x:Name="RbCuloareAlb" Content="Alb" GroupName="Culoare" Margin="0,0,6,0" />
                    <RadioButton x:Name="RbCuloareNegru" Content="Negru" GroupName="Culoare" />
                </StackPanel>

                <TextBlock Text="Opțiuni" Margin="0,8,0,0" />
                <StackPanel>
                    <CheckBox x:Name="ChkAer" Content="Aer condiționat" />
                    <CheckBox x:Name="ChkNavigatie" Content="Navigație" />
                    <CheckBox x:Name="ChkCutie" Content="Cutie automată" />
                </StackPanel>

                <UniformGrid Columns="3" Margin="0,10,0,0">
                    <Button x:Name="BtnAdd" Content="Adaugă" Click="BtnAdd_Click" Margin="4" Background="{StaticResource ButtonBrush}" />
                    <Button x:Name="BtnUpdate" Content="Actualizează" Click="BtnUpdate_Click" Margin="4" Background="{StaticResource ButtonBrush}" />
                    <Button x:Name="BtnDelete" Content="Șterge" Click="BtnDelete_Click" Margin="4" Background="{StaticResource ButtonBrush}" />
                </UniformGrid>

                <Separator Margin="0,10,0,10" />

                <TextBlock Text="Total mașini:" Margin="0,6,0,0" />
                <TextBlock x:Name="TxtTotalMasini" Text="0" FontWeight="Bold" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
